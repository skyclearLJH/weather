KMA_AUTH_KEY=your_kma_api_key
KMA_BROADCAST_AUTH_KEY=your_broadcast_kma_api_key
VITE_KMA_AUTH_KEY=your_kma_api_key
# Set to 1 to bypass persistent storage and restore live KIM processing immediately.
DISABLE_PRECOMPUTED_KIM=0
# Set to 1 to bypass persistent satellite frames and restore live NOAA processing.
DISABLE_PRECOMPUTED_SATELLITE=0
# Set to off to restore the original unsmoothed accumulated-rainfall 3D surface.
VITE_ACCUM_3D_SPATIAL_SMOOTHING=on
